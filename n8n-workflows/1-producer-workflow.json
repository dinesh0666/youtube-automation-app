        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "={{$env.SHOTSTACK_API_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "timeline",
              "value": "={\"tracks\": [{\"clips\": [{\"asset\": {\"type\": \"audio\", \"src\": \"data:audio/mp3;base64,\" + $node['Generate Voiceover (ElevenLabs)'].binary.data.toString('base64')}, \"start\": 0, \"length\": \"auto\"}]}, {\"clips\": {{$node['Generate Images (Pollinations)'].json.image_urls.split(',').map((url, i) => ({asset: {type: 'image', src: url}, start: i * 5, length: 5, transition: {in: 'fade', out: 'fade'}}))}}]}]}"
            },
            {
              "name": "output",
              "value": "={\"format\": \"mp4\", \"resolution\": \"1080\"}"
            }
          ]
        },
        "options": {}
      },
      "id": "create-video",
      "name": "Create Video (Shotstack)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "url": "={{$node['Webhook Trigger'].json.body.callbackUrl}}",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "completed"
