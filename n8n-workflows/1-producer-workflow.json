              "name": "model",
              "value": "claude-3-5-sonnet-20241022"
            },
            {
              "name": "max_tokens",
              "value": "1024"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"user\", \"content\": \"Generate 8 image prompts for this true crime video. Each prompt should describe a dramatic, cinematic scene.\\n\\nScript: {{$node['Write Script (Claude)'].json.content[0].text}}\\n\\nFormat: One prompt per line, 20-30 words each. Dark, moody, realistic style.\"}]"
            }
          ]
        },
        "options": {}
      },
      "id": "generate-image-prompts",
      "name": "Generate Image Prompts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1250, 400]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "image-urls",
              "name": "image_urls",
              "value": "={{$node['Generate Image Prompts'].json.content[0].text.split('\\n').filter(p => p.trim()).map(prompt => 'https://image.pollinations.ai/prompt/' + encodeURIComponent(prompt + ' cinematic dark moody realistic')).join(',')}}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "generate-images",
      "name": "Generate Images (Pollinations)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [1450, 400]
