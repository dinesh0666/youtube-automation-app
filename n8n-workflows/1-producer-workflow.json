              "value": "={{$node['Create Video (Shotstack)'].json.response.url}}"
            },
            {
              "name": "script",
              "value": "={{$node['Write Script (Claude)'].json.content[0].text}}"
            },
            {
              "name": "voiceoverUrl",
              "value": "data:audio/mp3;base64,..."
            },
            {
              "name": "duration",
              "value": "={{$node['Create Video (Shotstack)'].json.response.duration}}"
            }
          ]
        },
        "options": {}
      },
