            },
            {
              "name": "max_tokens",
              "value": "2048"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"user\", \"content\": \"Review this true crime script for accuracy, pacing, and engagement. Suggest improvements.\\n\\nScript: {{$node['Write Script (Claude)'].json.content[0].text}}\\n\\nCheck: Facts, flow, dramatic timing, audience engagement.\"}]"
            }
          ]
        },
        "options": {}
      },
      "id": "review-script",
      "name": "AI Review Script",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 200]
    },
    {
      "parameters": {
        "url": "https://api.elevenlabs.io/v1/text-to-speech/{{$env.ELEVENLABS_VOICE_EN}}",
